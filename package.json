{
  "name": "local-videoplayer",
  "version": "1.0.0",
  "description": "A lightweight, local, and private video player.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "keywords": [
    "video",
    "player",
    "local",
    "private"
  ],
  "author": {
    "name": "arielegs",
    "email": "none@none.com"
  },
  "build": {
    "appId": "com.arielegs.localvideoplayer",
    "productName": "LocalVideoPlayer",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Video"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png",
      "artifactName": "${productName} Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup.${ext}",
      "uninstallDisplayName": "${productName}",
      "packElevateHelper": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "files": [
      "**/*",
      "!.*",
      "!dev_data",
      "!dist",
      "!config.json",
      "!progress.json",
      "!last_played.json",
      "!config.example.json"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/ffmpeg",
      "node_modules/@ffprobe-installer/ffprobe"
    ]
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
